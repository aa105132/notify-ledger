# 不凡收款管理端配置
NL_ADDR=:8098
NL_DSN=epay:password@tcp(127.0.0.1:3306)/epay?parseTime=true&loc=Asia%2FShanghai&charset=utf8mb4
NL_TABLE_PREFIX=pre
NL_PUBLIC_BASE_URL=http://127.0.0.1:8098
NL_EPAY_BASE_URL=http://127.0.0.1
NL_EPAY_INTERNAL_SECRET=change-this-internal-secret
NL_ADMIN_TOKEN=change-this-admin-token
NL_AUTO_MIGRATE=true
NL_AUTO_REGISTER_DEVICE=false
NL_DEFAULT_DEVICE_SECRET=change-this-device-secret
# 收款账号分配策略：least_amount / least_orders / round_robin / random
NL_ACCOUNT_PICK_STRATEGY=least_amount
# 一键扫描已连接安卓设备时使用；可填 adb 绝对路径，如 /opt/android-sdk/platform-tools/adb
NL_ADB_PATH=adb
