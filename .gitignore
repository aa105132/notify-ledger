smsf_devices.json
smsf_bridge.log
*.log

# ---- 编译产物 / 二进制 ----
# 只忽略仓库根目录的编译产物，不要写成裸 bufan-ledger，
# 否则会连 cmd/bufan-ledger/ 源码目录一起忽略。
/bufan-ledger
/bufan-ledger.exe
*.exe
*.dll
*.so
*.dylib

# ---- Go 工作目录 ----
vendor/

# ---- 本地工具链（便携 PHP 等，不应入库）----
tools/

